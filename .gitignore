# Dependencies
# Never push node_modules to GitHub; it's huge and can be reinstalled via 'npm install'
node_modules/

# Build Output
# We usually push output.css so GitHub Pages can see it, 
# but we ignore the raw input/config backups if they are temporary.
.eslintcache
.stylelintcache

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Metadata
.DS_Store
Thumbs.db

# IDE / Editor Settings
.vscode/
.idea/
*.swp
*.swo

# Local Environment Variables
.env
.env.local